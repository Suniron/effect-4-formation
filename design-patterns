    <h2>Mediator</h2>
    <p class="intent"><b>Intention —</b> <b>Centraliser</b> les communications entre objets dans un médiateur, pour qu'ils ne se référencent plus directement.</p>

    <h3>Le problème</h3>
    <p>Quand chaque composant connaît tous les autres, on obtient un plat de spaghettis : couplage « tous-à-tous », impossible à faire évoluer.</p>
    <h3>La solution</h3>
    <p>Les composants ne parlent qu'au <i>médiateur</i> ; lui seul connaît tout le monde et orchestre les échanges.</p>

    <div class="code-block" data-file="mediator.ts"><script type="text/plain">interface ChatMediator {
  join(user: User): void
  send(from: string, message: string): void
}

class User {
  constructor(public name: string, private room: ChatMediator) {
    room.join(this)
  }
  send(msg: string) { this.room.send(this.name, msg) }   // parle AU médiateur
  receive(from: string, msg: string) { console.log(`[${this.name}] ${from}: ${msg}`) }
}

class ChatRoom implements ChatMediator {
  private users: User[] = []
  join(user: User) { this.users.push(user) }
  // Le médiateur décide qui reçoit quoi : les User restent découplés.
  send(from: string, message: string) {
    for (const u of this.users) if (u.name !== from) u.receive(from, message)
  }
}

const room = new ChatRoom()
const alice = new User("Alice", room)
const bob = new User("Bob", room)
alice.send("Salut !")   // Bob reçoit ; Alice et Bob ne se connaissent pas</script></div>

