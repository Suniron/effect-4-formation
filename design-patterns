<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Design Patterns — La formation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Spline+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#f3eee2;
    --paper-2:#ece5d6;
    --card:#fbf8f0;
    --ink:#16233d;
    --ink-soft:#46566f;
    --ink-faint:#8492a6;
    --line:rgba(22,35,61,.13);
    --line-strong:rgba(22,35,61,.22);
    --blue:#1f54d6;
    --blue-deep:#13234c;
    --create:#c1781a;   /* créationnels */
    --struct:#0e9787;   /* structurels  */
    --behav:#c33b86;    /* comportementaux */
    --radius:16px;
    --mono:"IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --sans:"Spline Sans",system-ui,sans-serif;
    --disp:"Bricolage Grotesque","Spline Sans",sans-serif;
    --code-bg:#0f1a30;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;scroll-padding-top:28px}
  body{
    margin:0;background:var(--paper);color:var(--ink);
    font-family:var(--sans);font-size:17px;line-height:1.7;
    -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;overflow-x:hidden;
  }
  /* blueprint grid */
  body::before{
    content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background-image:
      linear-gradient(rgba(31,84,214,.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(31,84,214,.045) 1px, transparent 1px);
    background-size:30px 30px;
    mask-image:radial-gradient(circle at 50% 30%, #000 60%, transparent 100%);
  }
  body::after{
    content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background:radial-gradient(900px 520px at 84% -6%, rgba(31,84,214,.10), transparent 60%);
  }
  #top-progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:60;
    background:linear-gradient(90deg,var(--blue),#5b8bff);box-shadow:0 0 10px rgba(31,84,214,.5)}
  a{color:var(--blue);text-decoration:none}
  a:hover{text-decoration:underline}
  code{font-family:var(--mono);font-size:.92em}

  /* ---------- HERO ---------- */
  .hero{position:relative;z-index:1;max-width:1140px;margin:0 auto;padding:84px 28px 36px}
  .eyebrow{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:12px;
    letter-spacing:.16em;text-transform:uppercase;color:var(--blue);
    border:1px solid var(--line-strong);border-radius:999px;padding:7px 14px;background:rgba(31,84,214,.05)}
  .eyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--blue);box-shadow:0 0 8px var(--blue)}
  .hero h1{font-family:var(--disp);font-weight:800;font-size:clamp(46px,9.5vw,108px);line-height:.9;
    margin:22px 0 0;letter-spacing:-.025em}
  .hero h1 em{font-style:normal;color:var(--blue);position:relative}
  .hero .lede{font-size:clamp(18px,2.4vw,23px);color:var(--ink-soft);max-width:680px;margin:20px 0 0;font-weight:420}
  .hero .lede b{color:var(--ink);font-weight:700}

  .families{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:40px 0 6px}
  .fcard{border:1px solid var(--line);border-top:3px solid var(--fc);border-radius:14px;padding:16px 18px;
    background:var(--card);box-shadow:0 18px 36px -28px rgba(22,35,61,.5)}
  .fcard .cnt{font-family:var(--disp);font-weight:800;font-size:34px;line-height:1;color:var(--fc)}
  .fcard .nm{font-family:var(--mono);font-size:12px;letter-spacing:.06em;text-transform:uppercase;
    color:var(--ink);margin-top:8px;font-weight:600}
  .fcard .ds{font-size:13.5px;color:var(--ink-soft);margin-top:6px;line-height:1.45}
  .fc-create{--fc:var(--create)} .fc-struct{--fc:var(--struct)} .fc-behav{--fc:var(--behav)}
  .scrollcue{margin-top:30px;font-family:var(--mono);font-size:12px;color:var(--ink-faint);letter-spacing:.08em}
  .scrollcue::after{content:" ↓";animation:bob 1.6s ease-in-out infinite;display:inline-block}
  @keyframes bob{50%{transform:translateY(5px)}}
  .hero>*{opacity:0;transform:translateY(14px);animation:rise .7s cubic-bezier(.2,.7,.2,1) forwards}
  .hero>*:nth-child(1){animation-delay:.05s}.hero>*:nth-child(2){animation-delay:.13s}
  .hero>*:nth-child(3){animation-delay:.21s}.hero>*:nth-child(4){animation-delay:.30s}
  .hero>*:nth-child(5){animation-delay:.40s}
  @keyframes rise{to{opacity:1;transform:none}}

  /* ---------- LAYOUT ---------- */
  .layout{position:relative;z-index:1;max-width:1300px;margin:0 auto;display:flex;gap:46px;
    padding:24px 28px 120px;align-items:flex-start}
  .sidebar{width:262px;flex:none;position:sticky;top:18px;max-height:calc(100vh - 36px);overflow:auto;padding-right:4px}
  .sidebar .sb-title{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;
    color:var(--ink-faint);margin:6px 0 12px}
  .toc{list-style:none;margin:0;padding:0}
  .toc .grp{font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--gc);font-weight:600;margin:18px 0 6px;display:flex;align-items:center;gap:7px}
  .toc .grp::before{content:"";width:8px;height:8px;border-radius:2px;background:var(--gc)}
  .toc .grp.create{--gc:var(--create)} .toc .grp.struct{--gc:var(--struct)} .toc .grp.behav{--gc:var(--behav)}
  .toc li a{display:flex;gap:9px;align-items:baseline;padding:5px 0 5px 13px;
    border-left:2px solid var(--line);margin-left:1px;color:var(--ink-soft);font-size:13.8px;font-weight:500;line-height:1.3}
  .toc li a .num{font-family:var(--mono);font-size:11px;color:var(--ink-faint);min-width:20px}
  .toc li a:hover{color:var(--ink);text-decoration:none}
  .toc li a.active{color:var(--blue);border-left-color:var(--blue);font-weight:700}
  .toc li a.active .num{color:var(--blue)}
  .sidebar .hint{margin-top:22px;font-size:12.5px;color:var(--ink-faint);line-height:1.5;
    border-top:1px solid var(--line);padding-top:16px}

  .content{flex:1;min-width:0;max-width:850px}

  /* ---------- SECTIONS ---------- */
  section{padding-top:42px;margin-top:14px;scroll-margin-top:22px}
  section+section{border-top:1px solid var(--line);margin-top:50px}
  .modtag{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:12px;
    letter-spacing:.1em;text-transform:uppercase;color:var(--fam,var(--blue));font-weight:600}
  .modtag .dot{width:8px;height:8px;border-radius:2px;background:var(--fam,var(--blue))}
  .fam-create{--fam:var(--create)} .fam-struct{--fam:var(--struct)} .fam-behav{--fam:var(--behav)}
  h2{font-family:var(--disp);font-weight:800;font-size:clamp(30px,4.8vw,48px);line-height:1;
    letter-spacing:-.02em;margin:9px 0 0}
  h3{font-family:var(--sans);font-weight:700;font-size:20px;margin:34px 0 4px;letter-spacing:-.01em;color:var(--ink)}
  h4{font-family:var(--mono);font-weight:600;font-size:13px;letter-spacing:.04em;color:var(--blue);
    text-transform:uppercase;margin:24px 0 4px}
  p{margin:13px 0;color:var(--ink-soft)}
  p b,li b{color:var(--ink);font-weight:700}
  .lead{font-size:18.5px;color:var(--ink);font-weight:450}
  ul,ol{color:var(--ink-soft);padding-left:22px}
  li{margin:6px 0}
  .ink{color:var(--ink)}
  .term{color:var(--blue);font-weight:700;border-bottom:1px dotted rgba(31,84,214,.45)}
  .intent{font-size:17.5px;color:var(--ink);margin:14px 0 4px;padding:12px 16px;
    border-left:3px solid var(--fam,var(--blue));background:var(--card);border-radius:0 12px 12px 0}
  .intent b{color:var(--fam,var(--blue))}

  /* ---------- CODE ---------- */
  .code-wrap{margin:18px 0;border-radius:14px;overflow:hidden;background:var(--code-bg);
    box-shadow:0 20px 46px -26px rgba(19,35,76,.7);border:1px solid rgba(31,84,214,.18)}
  .code-bar{display:flex;align-items:center;gap:8px;padding:9px 14px;background:rgba(255,255,255,.045);
    border-bottom:1px solid rgba(255,255,255,.07)}
  .code-bar .lights{display:flex;gap:6px}
  .code-bar .lights i{width:11px;height:11px;border-radius:50%;display:block}
  .lights i:nth-child(1){background:#ff5f57}.lights i:nth-child(2){background:#febc2e}.lights i:nth-child(3){background:#28c840}
  .code-bar .fname{font-family:var(--mono);font-size:11.5px;color:#8493ad;margin-left:4px}
  .code-bar .copy{margin-left:auto;font-family:var(--mono);font-size:11px;color:#aab6cd;
    background:transparent;border:1px solid rgba(255,255,255,.16);border-radius:7px;padding:4px 10px;cursor:pointer;transition:.18s}
  .code-bar .copy:hover{color:#fff;border-color:#5b8bff;background:rgba(91,139,255,.16)}
  pre{margin:0;padding:18px;overflow-x:auto;font-family:var(--mono);font-size:13px;line-height:1.62;tab-size:2}
  pre code{font-size:13px}
  .hljs{background:transparent;color:#d7deec}
  .hljs-comment,.hljs-quote{color:#6f7e98;font-style:italic}
  .hljs-keyword,.hljs-selector-tag{color:#82a9ff}
  .hljs-built_in,.hljs-title.class_,.hljs-title.class_.inherited__,.hljs-type,.hljs-namespace{color:#5fd3c6}
  .hljs-string,.hljs-regexp,.hljs-symbol{color:#aee0a0}
  .hljs-number,.hljs-literal{color:#f2bd76}
  .hljs-title,.hljs-title.function_,.hljs-section{color:#e7cd86}
  .hljs-attr,.hljs-attribute,.hljs-property{color:#d7deec}
  .hljs-params{color:#c3cce0}
  .hljs-variable,.hljs-template-variable,.hljs-subst{color:#d7deec}
  .hljs-meta{color:#8493ad}

  /* ---------- USAGE block ---------- */
  .usage{margin:16px 0;border:1px solid var(--line);border-left:3px solid var(--fam,var(--blue));
    border-radius:0 12px 12px 0;background:var(--card);overflow:hidden}
  .usage p{margin:0;padding:11px 16px;font-size:14.5px;color:var(--ink-soft)}
  .usage p+p{border-top:1px solid var(--line)}
  .usage .u-when b{color:#138a4e}
  .usage .u-warn b{color:#c0392b}
  .usage .u-when::before{content:"✅ ";} .usage .u-warn::before{content:"⚠️ ";}
  .analogy{font-size:15px;color:var(--ink-soft);font-style:italic;margin:14px 0;padding-left:6px}
  .analogy b{font-style:normal;color:var(--ink)}

  /* ---------- CALLOUTS ---------- */
  .callout{margin:20px 0;border:1px solid var(--line-strong);border-left-width:4px;border-radius:12px;
    padding:14px 17px;background:var(--card);display:flex;gap:14px;align-items:flex-start}
  .callout .ic{font-size:19px;line-height:1.5;flex:none}
  .callout .bd{flex:1}.callout p{margin:3px 0;color:var(--ink-soft)}
  .callout .lab{display:block;font-family:var(--mono);font-size:11px;letter-spacing:.09em;text-transform:uppercase;font-weight:700;margin-bottom:2px}
  .c-tip{border-left-color:var(--struct)} .c-tip .lab{color:var(--struct)}
  .c-warn{border-left-color:#d0432d} .c-warn .lab{color:#d0432d}
  .c-key{border-left-color:var(--blue);background:rgba(31,84,214,.05)} .c-key .lab{color:var(--blue)}
  .c-note{border-left-color:var(--create)} .c-note .lab{color:var(--create)}

  /* ---------- COMPARE ---------- */
  .compare{margin:20px 0;border:1px solid var(--line-strong);border-radius:14px;overflow:hidden;background:var(--card)}
  .ctabs{display:flex;border-bottom:1px solid var(--line)}
  .ctab{flex:1;font-family:var(--mono);font-size:12.5px;font-weight:600;color:var(--ink-faint);
    background:transparent;border:0;padding:11px 10px;cursor:pointer;transition:.18s;border-bottom:2px solid transparent}
  .ctab:hover{color:var(--ink-soft)}
  .ctab.active.bad{color:#c0392b;border-bottom-color:#c0392b;background:rgba(192,57,43,.06)}
  .ctab.active.good{color:#138a4e;border-bottom-color:#138a4e;background:rgba(19,138,78,.06)}
  .cpanel{display:none}.cpanel.active{display:block;animation:fade .25s ease}
  @keyframes fade{from{opacity:0}to{opacity:1}}
  .cpanel .code-wrap{margin:0;border:0;border-radius:0;box-shadow:none}
  .cnote{padding:10px 16px;font-size:13.5px;border-top:1px solid var(--line);color:var(--ink-soft)}
  .cnote.bad{background:rgba(192,57,43,.05)} .cnote.bad b{color:#c0392b}
  .cnote.good{background:rgba(19,138,78,.05)} .cnote.good b{color:#138a4e}

  /* ---------- decision / sheet ---------- */
  .decision{margin:20px 0;display:grid;gap:10px}
  .drow{display:flex;gap:14px;align-items:flex-start;border:1px solid var(--line);border-radius:12px;
    padding:13px 16px;background:var(--card)}
  .drow .sym{flex:1;color:var(--ink);font-weight:500}
  .drow .pat{flex:none;font-family:var(--mono);font-size:13px;color:var(--blue);font-weight:600;text-align:right;max-width:46%}
  .sheet{margin:22px 0;border:1px solid var(--line-strong);border-radius:14px;overflow:hidden;background:var(--card)}
  .sheet table{border-collapse:collapse;width:100%;font-size:14px}
  .sheet th,.sheet td{text-align:left;padding:10px 14px;border-bottom:1px solid var(--line);vertical-align:top}
  .sheet th{font-family:var(--mono);font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--blue);background:rgba(31,84,214,.05)}
  .sheet td:first-child{font-family:var(--mono);color:var(--ink);white-space:nowrap;font-weight:600}
  .sheet tr:last-child td{border-bottom:0}
  .sheet .hd-create td{background:rgba(193,120,26,.08);color:var(--create);font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:700}
  .sheet .hd-struct td{background:rgba(14,151,135,.08);color:var(--struct);font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:700}
  .sheet .hd-behav td{background:rgba(195,59,134,.08);color:var(--behav);font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:700}

  #navbtn{display:none}
  footer{position:relative;z-index:1;max-width:1300px;margin:0 auto;padding:28px 28px 70px;
    border-top:1px solid var(--line);color:var(--ink-faint);font-size:14px}
  footer b{color:var(--ink-soft)}
  .overlay{display:none}

  @media(max-width:1000px){
    body{font-size:16px}
    .layout{display:block;padding:18px 20px 90px}
    .content{max-width:none}
    .families{grid-template-columns:1fr}
    .sidebar{position:fixed;top:0;left:0;height:100dvh;width:84vw;max-width:320px;z-index:50;
      background:var(--paper-2);border-right:1px solid var(--line-strong);padding:72px 20px 28px 22px;
      transform:translateX(-104%);transition:transform .3s cubic-bezier(.3,.7,.2,1);max-height:none;
      box-shadow:30px 0 60px -30px rgba(22,35,61,.5)}
    .sidebar.open{transform:none}
    .overlay{display:block;position:fixed;inset:0;background:rgba(22,35,61,.4);z-index:45;opacity:0;pointer-events:none;transition:.3s}
    .overlay.show{opacity:1;pointer-events:auto}
    #navbtn{display:inline-flex;align-items:center;gap:8px;position:fixed;left:16px;bottom:18px;z-index:55;
      font-family:var(--mono);font-size:13px;font-weight:600;color:#fff;
      background:linear-gradient(90deg,var(--blue),#4f7bff);border:0;border-radius:999px;padding:12px 18px;cursor:pointer;
      box-shadow:0 12px 28px -8px rgba(31,84,214,.6)}
    .hero{padding:60px 20px 22px}
    .drow{flex-direction:column;gap:6px}.drow .pat{text-align:left;max-width:none}
  }
</style>
</head>
